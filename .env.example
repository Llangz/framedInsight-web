# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Tiara Connect SMS/OTP Configuration (Meliora Technologies)
TIARA_API_KEY=your-tiara-api-key
TIARA_SENDER_ID=CONNECT

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# LipaChat WhatsApp API
LIPACHAT_API_KEY=your-lipachat-api-key
LIPACHAT_WEBHOOK_SECRET=your-webhook-secret
LIPACHAT_PHONE_NUMBER=+254XXXXXXXXX

# OpenAI API (for AI agents)
OPENAI_API_KEY=sk-your-openai-key

# Agromonitoring API (for satellite imagery)
AGROMONITORING_API_KEY=your-agromonitoring-key

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=framedInsight

# M-Pesa Integration (for payments - future)
MPESA_CONSUMER_KEY=your-mpesa-key
MPESA_CONSUMER_SECRET=your-mpesa-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey

# Email (for notifications - future)
RESEND_API_KEY=your-resend-key
EMAIL_FROM=notifications@framedinsight.com

